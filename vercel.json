{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(assets/.*)", "destination": "/dist/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

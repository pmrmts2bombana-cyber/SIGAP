rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // Helper functions
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128;
    }

    // Session helpers
    function getSession() {
      return get(/databases/$(database)/documents/activeSessions/$(request.auth.uid)).data;
    }

    function hasActiveSession() {
      return isSignedIn() && exists(/databases/$(database)/documents/activeSessions/$(request.auth.uid));
    }

    function hasRole(roles) {
      return hasActiveSession() && getSession().role in roles;
    }

    function isAdmin() {
      return hasRole(['Admin']);
    }

    function isTeacherOrAdmin() {
      return hasRole(['Admin', 'Guru']);
    }

    function isStudent() {
      return hasRole(['Siswa']);
    }

    // Password verification helper (zero-trust, backward compatible)
    function verifyTeacherPassword(nip, pass) {
      return (
        (exists(/databases/$(database)/documents/teachers/$(nip)/private/password) &&
         get(/databases/$(database)/documents/teachers/$(nip)/private/password).data.pass == pass) ||
        (exists(/databases/$(database)/documents/teachers/$(nip)) &&
         get(/databases/$(database)/documents/teachers/$(nip)).data.pass == pass)
      );
    }

    // Validation Helpers
    function isValidStudent(data) {
      return data.nisn is string && data.nisn.size() > 0 && data.nisn.size() <= 64 &&
             data.nama is string && data.nama.size() > 0 && data.nama.size() <= 256;
    }

    function isValidTeacher(data) {
      return data.nip is string && data.nip.size() > 0 && data.nip.size() <= 64 &&
             data.nama is string && data.nama.size() > 0 && data.nama.size() <= 256;
    }

    // Rules for Active Sessions (Secure login bridging)
    match /activeSessions/{authUid} {
      allow read: if isSignedIn() && request.auth.uid == authUid;
      allow create, update: if isSignedIn() && request.auth.uid == authUid && (
        // Student login
        (incoming().role == 'Siswa' && exists(/databases/$(database)/documents/students/$(incoming().nisn))) ||
        // Teacher login (verified securely against hashed/private credentials)
        (incoming().role in ['Guru', 'Admin'] && verifyTeacherPassword(incoming().nip, incoming().pass))
      );
      allow delete: if isSignedIn() && request.auth.uid == authUid;
    }

    // 1. appConfig
    match /appConfig/{id} {
      allow read: if true; // Public for theme/logo configs
      allow write: if isAdmin();
    }

    // 2. students
    match /students/{nisn} {
      allow read: if isTeacherOrAdmin() || (isStudent() && string(getSession().nisn) == string(nisn));
      allow create: if isTeacherOrAdmin() && isValidStudent(incoming());
      allow update: if isTeacherOrAdmin() || (isStudent() && string(getSession().nisn) == string(nisn));
      allow delete: if isAdmin();
    }

    // 3. teachers
    match /teachers/{nip} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidTeacher(incoming());
      allow delete: if isAdmin();

      // 3.1 private credentials
      match /private/password {
        allow read, write: if false; // Denied to all client SDK reads/writes
      }
    }

    // 4. classrooms
    match /classrooms/{nama} {
      allow read: if isTeacherOrAdmin() || isStudent();
      allow write: if isAdmin();
    }

    // 5. attendance
    match /attendance/{id} {
      allow read: if isTeacherOrAdmin() || (isStudent() && getSession().nisn == resource.data.nisn);
      allow write: if isTeacherOrAdmin();
    }

    // 6. teacherAttendance
    match /teacherAttendance/{id} {
      allow read: if isTeacherOrAdmin();
      allow write: if isTeacherOrAdmin();
    }

    // 7. teachingSchedules
    match /teachingSchedules/{id} {
      allow read: if isTeacherOrAdmin() || isStudent();
      allow write: if isAdmin();
    }

    // 8. settings
    match /settings/{id} {
      allow read: if isTeacherOrAdmin() || isStudent();
      allow write: if isAdmin();
    }

    // 9. holidays
    match /holidays/{id} {
      allow read: if isTeacherOrAdmin() || isStudent();
      allow write: if isAdmin();
    }

    // 10. roster
    match /roster/{id} {
      allow read: if isTeacherOrAdmin() || isStudent();
      allow write: if isAdmin();
    }

    // 11. rekapSiswa
    match /rekapSiswa/{id} {
      allow read: if isTeacherOrAdmin() || isStudent();
      allow write: if isTeacherOrAdmin();
    }

    // 12. oneTimeTokens
    match /oneTimeTokens/{id} {
      allow read: if isTeacherOrAdmin();
      allow write: if isTeacherOrAdmin();
    }
  }
}

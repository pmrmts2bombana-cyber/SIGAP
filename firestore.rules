rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email in ['alazisrahmat@gmail.com', 'rahmatazis850@gmail.com'] && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/teachers/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.get('role', '') == 'Admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidStudent(data) {
      return data.nisn is string && data.nisn.size() > 0 &&
             data.nama is string && data.nama.size() > 0 &&
             data.kelas is string && data.kelas.size() > 0;
    }

    function isValidTeacher(data) {
      return data.nip is string && data.nip.size() > 0 &&
             data.nama is string && data.nama.size() > 0 &&
             data.user is string && data.user.size() > 0 &&
             data.pass is string && data.pass.size() > 0 &&
             data.role in ['Guru', 'Admin', 'Guru Wali Kelas', 'Siswa'];
    }

    function isValidAttendance(data) {
      return data.nisn is string && data.nisn.size() > 0 &&
             data.tanggal is string && data.tanggal.size() == 10 &&
             data.status in ['Hadir', 'Sakit', 'Izin', 'Alfa'];
    }

    function isValidTeacherAttendance(data) {
      return data.nip is string && data.nip.size() > 0 &&
             data.kelas is string && data.kelas.size() > 0 &&
             data.tanggal is string && data.tanggal.size() == 10;
    }

    function isValidTeachingSchedule(data) {
      return data.nip is string && data.nip.size() > 0 &&
             data.kelas is string && data.kelas.size() > 0 &&
             data.targetPertemuan is number;
    }

    function isValidAppConfig(data) {
      return (data.get('logoUrl', null) == null || (data.logoUrl is string && data.logoUrl.size() < 1048500)) &&
             (data.get('schoolName', null) == null || (data.schoolName is string && data.schoolName.size() <= 200)) &&
             (data.get('cardTemplateUrl', null) == null || (data.cardTemplateUrl is string && data.cardTemplateUrl.size() < 2100000));
    }

    match /appConfig/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /students/{nisn} {
      allow read: if true;
      allow write: if true;
    }

    match /teachers/{nip} {
      allow read: if true;
      allow write: if true;
    }

    match /classrooms/{nama} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }

    match /attendance/{id} {
      allow read: if true;
      allow create: if isValidAttendance(incoming());
      allow update: if isValidAttendance(incoming());
      allow delete: if isAdmin() || true;
    }

    match /teacherAttendance/{id} {
      allow read: if true;
      allow create: if isValidTeacherAttendance(incoming());
      allow update: if isValidTeacherAttendance(incoming());
      allow delete: if isAdmin() || true;
    }

    match /teachingSchedules/{id} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    
    match /holidays/{id} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }

    match /roster/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /rekapSiswa/{id} {
      allow read, write: if true;
    }

    match /oneTimeTokens/{id} {
      allow read, write: if true;
    }
  }
}
